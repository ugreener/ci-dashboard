                                    'runs: 1,' +
                                    'failures: 1' +
                                '})' +
                            '});' +
                            'const data = await response.json();' +
                            'if (!response.ok) throw new Error(data.error || "Failed to create Jira");' +
                            'if (data.status === "existing" || data.status === "created") {' +
                                'window.open(data.issue_url, "_blank");' +
                                'button.innerHTML = "<img src=\\"https://play-lh.googleusercontent.com/_AZCbg39DTuk8k3DiPRASr9EwyW058pOfzvAu1DsfN9ygtbOlbuucmXaHJi5ooYbokQX=s48\\" width=\\"20\\" height=\\"20\\" alt=\\"Jira\\"><span>" + data.issue_key + "</span>";' +
                                'button.style.background = "#10b981";' +
                                'button.onclick = () => window.open(data.issue_url, "_blank");' +
                                'alert((data.status === "created" ? "Jira created: " : "Existing Jira found: ") + data.issue_key);' +
                            '} else if (data.status === "disabled") {' +
                                'alert("Jira integration is not enabled");' +
                                'button.disabled = false;' +
                                'button.innerHTML = originalContent;' +
                            '}' +
                        '} catch (error) {' +
                            'alert("Failed to create Jira: " + error.message);' +
                            'button.disabled = false;' +
                            'button.innerHTML = originalContent;' +
                        '}' +
                    '}' +
                    'async function analyzeFailureInWindow() {' +
                        'const button = document.getElementById("analyzeButton");' +
                        'const originalContent = button.innerHTML;' +
                        'const analysisWindow = window.open("", "_blank");' +
                        'if (!analysisWindow) {' +
                            'alert("Please allow popups for this site to view AI analysis results");' +
                            'return;' +
                        '}' +
                        'analysisWindow.document.write("<html><body><h2>Analyzing...</h2><p>Please wait while AI analyzes the failure...</p></body></html>");' +
                        'try {' +
                            'button.disabled = true;' +
                            'button.innerHTML = "<span>Analyzing...</span>";' +
                            'const response = await fetch("/api/analyze-failure", {' +
                                'method: "POST",' +
                                'headers: {"Content-Type": "application/json"},' +
                                'body: JSON.stringify({' +
                                    'test_name: jiraMetadata.testName,' +
                                    'version: jiraMetadata.version,' +
                                    'platform: jiraMetadata.platform,' +
                                    'error_message: jiraMetadata.errorMessage,' +
                                    'use_cached: true' +
                                '})' +
                            '});' +
                            'const data = await response.json();' +
                            'if (!response.ok) {' +
                                'analysisWindow.close();' +
                                'throw new Error(data.error || "Analysis failed");' +
