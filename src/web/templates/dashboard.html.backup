                        linkText = 'View in Prow';
                    }
                }

                metadataHtml = '<div class="metadata">' +
                    '<div class="meta-row">' +
                        '<span class="meta-label">Timestamp:</span>' +
                        '<span class="meta-value">' + formattedTimestamp + '</span>' +
                    '</div>' +
                    '<div class="meta-row">' +
                        '<span class="meta-label">Platform:</span>' +
                        '<span class="meta-value platform-badge">' + (metadata.platform || 'Unknown') + '</span>' +
                    '</div>' +
                    '<div class="meta-row">' +
                        '<span class="meta-label">Job:</span>' +
                        '<span class="meta-value">' + (metadata.jobName || 'Unknown') + '</span>' +
