                    '</div>' +
                    (metadata.jobUrl ?
                        '<div class="meta-row">' +
                            '<span class="meta-label">Job URL:</span>' +
                            '<span class="meta-value"><a href="' + metadata.jobUrl + '" target="_blank" style="color: #2563eb; text-decoration: underline;">' + linkText + '</a></span>' +
                        '</div>'
                    : '') +
                    (metadata.testName ?
                        '<div class="meta-row" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; gap: 10px;">' +
                            '<button onclick="fileJira()" id="jiraButton" style="background: #0052CC; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 13px; display: flex; align-items: center; gap: 8px;">' +
                                '<img src="https://play-lh.googleusercontent.com/_AZCbg39DTuk8k3DiPRASr9EwyW058pOfzvAu1DsfN9ygtbOlbuucmXaHJi5ooYbokQX=s48" width="20" height="20" alt="Jira">' +
                                '<span>File Jira Issue</span>' +
                            '</button>' +
                            '<button onclick="analyzeFailureInWindow()" id="analyzeButton" style="background: #3b82f6; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 13px; display: flex; align-items: center; gap: 8px;">' +
                                '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 22.5l-.394-1.933a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"></path></svg>' +
                                '<span>AI Analyze</span>' +
                            '</button>' +
                        '</div>'
                    : '') +
                '</div>';
            }

            // Build the script section using string concatenation to avoid template literal nesting
            let scriptSection = '';
            if (metadata.testName) {
                scriptSection = '<script>' +
                    'const jiraMetadata = {' +
                        'testName: ' + JSON.stringify(metadata.testName) + ',' +
                        'testDescription: ' + JSON.stringify(metadata.testDescription || '') + ',' +
                        'version: ' + JSON.stringify(metadata.version || '') + ',' +
                        'platform: ' + JSON.stringify(metadata.platform || '') + ',' +
                        'jobUrl: ' + JSON.stringify(metadata.jobUrl || '') + ',' +
                        'errorMessage: ' + JSON.stringify(logContent) +
                    '};' +
                    'async function fileJira() {' +
                        'const button = document.getElementById("jiraButton");' +
                        'const originalContent = button.innerHTML;' +
                        'try {' +
                            'button.disabled = true;' +
                            'button.innerHTML = "<span>Filing Jira...</span>";' +
                            'const response = await fetch("/api/jira/create", {' +
                                'method: "POST",' +
                                'headers: {"Content-Type": "application/json"},' +
                                'body: JSON.stringify({' +
                                    'test_name: jiraMetadata.testName,' +
